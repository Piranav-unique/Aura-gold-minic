# App Settings
ENVIRONMENT=development
PROJECT_NAME="AGS Gold API"
API_V1_STR="/api/v1"

# Security Settings
SECRET_KEY=change_this_to_a_secure_random_string_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://localhost:5173"]

# Database Configuration (PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password123
POSTGRES_DB=ags_gold_db
POSTGRES_PORT=5435

# Async Database URL — local Docker only; on Railway set DATABASE_URL in service Variables
# DATABASE_URL=postgresql+asyncpg://postgres:password123@localhost:5435/ags_gold_db

#To run smoke tests
RUN_SMOKE_TESTS=true

# Live metal prices (GoldAPI primary for testing + fallbacks)
API_NINJAS_KEY=
GOLDAPI_KEY=c73b2356a1ac217a89e3966c53466fde313f61f43be49579352ed1a8699a54b4
GOLD_API_BASE_URL=https://api.gold-api.com
COMMODITY_PRICE_API_KEY=6a6a8fde-c7a1-4789-bbf7-c80e2a1eb484
METALPRICEAPI_KEY=1d9ee69436af1474bb3c238cda351d93
# Cache live prices 30 min to stay within API quotas
METAL_PRICES_CACHE_TTL_SECONDS=1800
METAL_GOLD_TN_BULLION_MARKUP_PERCENT=19.05
METAL_SILVER_TN_BULLION_MARKUP_PERCENT=28.6

# Signup SMS OTP — MSG91 v5 OTP (same as Postman: /api/v5/otp)
MSG91_AUTH_KEY=531756AmeZWT77Yo0d6a3bcfc6P1
# OTP API template_id — MSG91 → SendOTP → copy Template ID (Postman uses this)
MSG91_OTP_TEMPLATE_ID=6a3a73a1a51ea2ee050db8b6
# Same ID for Flow API (AurumGoldSilvers_OTP_v2 — Verified by DLT)
MSG91_FLOW_ID=6a3a73a1a51ea2ee050db8b6
MSG91_SMS_CHANNELS=otp
SMS_SENDER_ID=AURUS
SMS_ROUTE=4
SIGNUP_OTP_LENGTH=6
SIGNUP_OTP_DEV_CODE=123456
SIGNUP_OTP_MAX_SENDS_PER_HOUR=10
# true = MSG91 generates OTP (same as Postman); false = app generates OTP
SIGNUP_OTP_USE_MSG91_VERIFY=true
# Jio DLT — PE ID + AurumGoldSilvers_OTP_v2 (header AURUS)
MSG91_DLT_TE_ID=1201178184118013406
MSG91_DLT_TEMPLATE_ID=1207178213595398801

# Bank link OTP — Aurum_Bank_Add_OTP (Flow template, DLT 1207178235534667442)
MSG91_BANK_OTP_TEMPLATE_ID=6a4a7eae9fe09e57d9000643
MSG91_BANK_FLOW_ID=6a4a7eae9fe09e57d9000643
MSG91_BANK_DLT_TEMPLATE_ID=1207178235534667442
MSG91_BANK_OTP_LENGTH=6
MSG91_BANK_OTP_USE_MSG91_VERIFY=false
MSG91_BANK_SMS_CHANNELS=flow,sendhttp


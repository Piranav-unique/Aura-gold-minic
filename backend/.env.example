# App Settings
# Railway: set ENVIRONMENT=production, PORT is injected automatically
ENVIRONMENT=development
PROJECT_NAME="AGS Gold API"
API_V1_STR="/api/v1"

# Security Settings
SECRET_KEY=change_this_to_a_secure_random_string_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_MOBILE_NUMBER=9943795005
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://localhost:5173"]

# Database Configuration (PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password123
POSTGRES_DB=ags_gold_db
POSTGRES_PORT=5435

# Async Database URL for SQLAlchemy (asyncpg)
# Railway Postgres: paste DATABASE_URL from the plugin (postgresql:// is auto-converted)
DATABASE_URL=postgresql+asyncpg://postgres:password123@localhost:5435/ags_gold_db

# Live metal prices (optional — app uses simulated data if unset)
API_NINJAS_KEY=
API_NINJAS_BASE_URL=https://api.api-ninjas.com/v1
COMMODITY_PRICE_API_KEY=
COMMODITY_PRICE_API_BASE_URL=https://api.commoditypriceapi.com/v2
GOLDAPI_KEY=
GOLD_API_BASE_URL=https://api.gold-api.com
METALPRICEAPI_KEY=
METALPRICEAPI_BASE_URL=https://api.metalpriceapi.com
METAL_PRICES_CACHE_TTL_SECONDS=1800

# Tamil Nadu retail adjustments (applied on top of international spot)
METAL_GOLD_IMPORT_DUTY_PERCENT=6
METAL_GOLD_GST_PERCENT=3
METAL_SILVER_IMPORT_DUTY_PERCENT=10
METAL_SILVER_GST_PERCENT=3
METAL_TN_JEWELLER_PREMIUM_PERCENT=1.25
METAL_GOLD_TN_BULLION_MARKUP_PERCENT=19.2
METAL_SILVER_TN_BULLION_MARKUP_PERCENT=28.6

# Signup SMS OTP (MSG91 v5 OTP template — set MSG91_OTP_TEMPLATE_ID from MSG91 panel)
MSG91_AUTH_KEY=
MSG91_OTP_URL=https://control.msg91.com/api/v5/otp
MSG91_OTP_TEMPLATE_ID=
MSG91_SEND_URL=https://api.msg91.com/api/sendhttp.php
# Jio DLT Principal Entity ID + approved content template ID (from DLT portal)
MSG91_DLT_TE_ID=
MSG91_DLT_TEMPLATE_ID=
SMS_SENDER_ID=CP-AURUS-S
SMS_ROUTE=4
SIGNUP_OTP_LENGTH=6
# Comma-separated MSG91 channel order: sendotp, flow, otp, sendhttp
MSG91_SMS_CHANNELS=sendotp,flow,otp
SIGNUP_OTP_MAX_SENDS_PER_HOUR=10
SIGNUP_OTP_MIN_RESEND_SECONDS=30

SIGNUP_OTP_USE_MSG91_VERIFY=true

# Bank link OTP — Aurum_Bank_Add_OTP (SendOTP template + DLT 1207178235534667442)
# Hex Template ID from MSG91 SendOTP → Templates (NOT the DLT ID 1207178235534667442)
MSG91_BANK_OTP_TEMPLATE_ID=6a4a7eae9fe09e57d9000643
MSG91_BANK_FLOW_ID=6a4a7eae9fe09e57d9000643
MSG91_BANK_DLT_TEMPLATE_ID=1207178235534667442
MSG91_BANK_OTP_LENGTH=6
MSG91_BANK_OTP_USE_MSG91_VERIFY=true
MSG91_BANK_SMS_CHANNELS=otp,sendotp
MSG91_BANK_SENDER_ID=AURUS
# Set false to send real bank-link OTP SMS in local development
BANK_OTP_DEV_MODE=false

# Sandbox KYC — Aadhaar OTP + PAN–Aadhaar link (set both for production; mock OTP 123456 if unset)
SANDBOX_API_KEY=
SANDBOX_API_SECRET=
SANDBOX_BASE_URL=https://api.sandbox.co.in
SANDBOX_API_VERSION=1.0.0
KYC_VERIFICATION_REASON=AURUM gold trading KYC verification

# Android in-app update (set after publishing APK — version_code must match pubspec +N)
APP_ANDROID_VERSION_NAME=0.1.0
APP_ANDROID_VERSION_CODE=1
APP_ANDROID_APK_URL=
APP_ANDROID_RELEASE_NOTES=
APP_ANDROID_FORCE_UPDATE=false

# Razorpay — gold/silver purchase checkout
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR
RAZORPAY_PLATFORM_FEE_PERCENT=2.0
RAZORPAY_PLATFORM_FEE_GST_PERCENT=18.0
# Simulate checkout in development when Razorpay keys are unset
PAYMENT_DEV_MOCK=true
